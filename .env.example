NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
DATABASE_MODE=auto

MONGODB_URI=mongodb://mongo:27017/lead_intelligence
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_SECRET=replace-with-secret-1
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_SECRET=replace-with-secret-2
REFRESH_TOKEN_EXPIRES=30d
BCRYPT_SALT_ROUNDS=12

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=http://localhost:5173
OPENAI_API_KEY=

SCRAPER_TIMEOUT_MS=25000
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; LeadIntelligenceBot/1.0; +https://example.com/bot)
SCRAPER_HEADLESS=true
SCRAPER_CONCURRENCY=3

DAILY_COMPANY_REFRESH_CRON=0 2 * * *
DAILY_HIRING_REFRESH_CRON=0 3 * * *
WEEKLY_CONTACT_REFRESH_CRON=0 4 * * 1
WEEKLY_TECH_REFRESH_CRON=0 5 * * 1
